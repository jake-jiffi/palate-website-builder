<!-- The status pill above the hero heading: a rounded, bordered, short-text label
     (with a status dot) sitting immediately above the hero h1. hero-status-pill must
     catch it. On the hero it must not appear at all. -->
<section class="hero">
  <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-3 py-1 text-sm">
    <span class="dot"></span> Now in beta
  </div>
  <h1>Build something real</h1>
  <p>Subhead carries the rest.</p>
</section>
