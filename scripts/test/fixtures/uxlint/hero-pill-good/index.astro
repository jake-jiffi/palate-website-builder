<!-- Clean hero: the heading carries it, no pill above the h1. A rounded CTA button is
     a link/action (not eyebrow chrome) and must NOT fire. A pill chip lower down the
     page, away from the hero, must NOT fire either. -->
<section class="hero">
  <h1>Build something real</h1>
  <a href="/start" class="rounded-full border bg-accent px-4 py-2">Get started</a>
</section>
<section class="features">
  <div class="rounded-full border bg-white px-3 py-1">New</div>
  <h2>What you get</h2>
</section>
