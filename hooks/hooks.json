{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__palate__.*",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/palate-manifest.mjs\"" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/palate-manifest.mjs\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/palate-pretooluse.mjs\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/palate-stop.mjs\"" }
        ]
      }
    ]
  }
}
