# Vercel hosts this project. Set these env vars in the Vercel dashboard
# (Project Settings -> Environment Variables), scoped per environment
# (Production / Preview / Development), OR keep a local .env for `vercel dev`.
# `provision-vercel.sh` pushes them via `vercel env add`. See
# references/hosting-vercel.md.

# Build-time vars - @sanity/astro reads these at `astro build`.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# "true" on the PREVIEW environment only - turns on click-to-edit overlays.
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false

# "true" during the EXPLORE stage - shows the top-bar variant switcher and
# the section-ID labels on each variant. Flip to "false" at Compose time.
# On Vercel: set per-environment (Preview: true during Explore, then false).
# See references/explore-stage.md.
PUBLIC_EXPLORE_MODE=false

# Runtime - read by /api/contact and the seed scripts via process.env.
SANITY_API_WRITE_TOKEN=
RESEND_API_KEY=
TURNSTILE_SECRET=

# Vercel injects these automatically per deployment (listed for reference):
#   VERCEL_ENV       - "production" | "preview" | "development"
#   VERCEL_URL       - the deployment URL
#   VERCEL_GIT_COMMIT_SHA, VERCEL_REGION, VERCEL_PROJECT_ID, VERCEL_TARGET_ENV
