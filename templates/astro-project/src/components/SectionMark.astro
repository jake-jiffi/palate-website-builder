---
// Small label visible in Explore mode (PUBLIC_EXPLORE_MODE=true) so the team
// can reference sections precisely - "v3 hero, v7 cta". Hidden in production.
// See references/explore-stage.md. Wrap each variant section with one:
//
//   <section class="relative ...">
//     <SectionMark id="v3-hero" />
//     ...
//   </section>
//
// The parent section needs `position: relative` for the label to anchor.
interface Props {
  id: string;
}
const { id } = Astro.props;
const show = import.meta.env.PUBLIC_EXPLORE_MODE === "true";
---
{show && (
  <span
    class="pointer-events-none absolute left-2 top-2 z-40 rounded bg-black/80 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-white"
    data-section-id={id}
  >
    {id}
  </span>
)}
