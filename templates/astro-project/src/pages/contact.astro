---
// Contact page: the reachable surface for the form. The form POSTs to the
// /api/contact handler already in the template. Compose may repurpose, restyle
// or remove this; it ships so the form exists end to end and the rendered gate
// (scripts/verify-rendered.sh) has a route to exercise.
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
---
<BaseLayout title="Contact" description="Send us a message and we will get back to you.">
  <section class="bg-brand-bg px-6 py-24">
    <div class="mx-auto max-w-xl">
      <h1 class="font-display text-brand-text text-4xl md:text-5xl">Get in touch</h1>
      <p class="text-brand-muted mt-4 text-lg">Send us a message and we will get back to you.</p>
      <ContactForm />
    </div>
  </section>
</BaseLayout>
