# Copy to .env and fill in. .env is git-ignored - never commit real values.
#
# PREVIEW STAGE: leave SANITY_PROJECT_ID empty. The site renders entirely from
# src/lib/content.ts - no Sanity account needed.
#
# PRODUCTION: fill these in after the Sanity project is created. In CI these
# same names must be set as BUILD environment variables - @sanity/astro reads
# SANITY_* and PUBLIC_SANITY_* at build time. See references/cms-and-draft-preview.md.

# --- Build-time (astro build / @sanity/astro) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Read token (Viewer role) - serves draft content for visual editing.
SANITY_API_READ_TOKEN=

# "true" only on the PREVIEW deployment - turns on click-to-edit overlays.
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false

# "true" during the EXPLORE stage - shows the top-bar variant switcher and
# section-ID labels on each variant. Flip to "false" at Compose time, before
# the Scaffold continues. See references/explore-stage.md.
PUBLIC_EXPLORE_MODE=false

# --- Runtime Worker secrets (also handy locally) ---
# Write token (Editor role) - `npm run seed` / `publish-all` and /api/contact.
SANITY_API_WRITE_TOKEN=

# Contact form (optional until the form is wired up):
RESEND_API_KEY=
TURNSTILE_SECRET=
