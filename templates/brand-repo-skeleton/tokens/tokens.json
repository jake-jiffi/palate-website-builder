{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Source of truth. Edit here, regenerate the other three formats. Placeholder values; replace per client.",
  "palette": {
    "white": { "base": { "$type": "color", "$value": "#ffffff" } },
    "ink": { "900": { "$type": "color", "$value": "#0f172a" }, "500": { "$type": "color", "$value": "#64748b" } },
    "accent": { "500": { "$type": "color", "$value": "#2563eb" }, "600": { "$type": "color", "$value": "#1d4ed8" } },
    "border": { "default": { "$type": "color", "$value": "#e2e8f0" } }
  },
  "brand": {
    "bg": {
      "default": { "$type": "color", "$value": "{palette.white.base}" },
      "inverse": { "$type": "color", "$value": "{palette.ink.900}" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "{palette.ink.900}" },
      "muted": { "$type": "color", "$value": "{palette.ink.500}" },
      "inverse": { "$type": "color", "$value": "{palette.white.base}" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "{palette.accent.500}" },
      "hover": { "$type": "color", "$value": "{palette.accent.600}" }
    },
    "border": { "default": { "$type": "color", "$value": "{palette.border.default}" } }
  },
  "type": {
    "family": {
      "display": { "$type": "fontFamily", "$value": "BrandDisplay" },
      "body": { "$type": "fontFamily", "$value": "BrandSans" }
    },
    "size": {
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.5rem" },
      "2xl": { "$type": "dimension", "$value": "2rem" },
      "3xl": { "$type": "dimension", "$value": "3rem" }
    }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "16": { "$type": "dimension", "$value": "4rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0.25rem" },
    "default": { "$type": "dimension", "$value": "0.5rem" },
    "lg": { "$type": "dimension", "$value": "1rem" }
  }
}
